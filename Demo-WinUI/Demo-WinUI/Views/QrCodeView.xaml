<Page
    x:Class="Net.Codecrete.QrCodeGenerator.Demo.Views.QrCodeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Net.Codecrete.QrCodeGenerator.Demo"
    xmlns:views="using:Net.Codecrete.QrCodeGenerator.Demo.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="20,16,20,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <views:QrCodeControl x:Name="QrCodeControl" Text="{x:Bind settings.Text, Mode=OneWay}"
                             BorderWidth="{x:Bind settings.BorderWidth, Mode=OneWay}"
                             ErrorCorrectionLevel="{x:Bind settings.EccLevel, Mode=OneWay}"
                             Grid.Row="0" Margin="0,0,0,16" />

        <TextBox x:Name="QrCodeTextBox" Text="{x:Bind settings.Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Grid.Row="1" Padding="5,3" Margin="0,6"/>
        
        <VariableSizedWrapGrid Grid.Row="2" Orientation="Horizontal">
            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Padding="0,5,12,5">Error Correction:</TextBlock>
                <ComboBox x:Name="ErrorCorrectionCombo"
                          ItemsSource="{x:Bind ErrorCorrectionLevels, Mode=OneTime}" DisplayMemberPath="Item1" SelectedValuePath="Item2"
                          SelectedValue="{x:Bind settings.EccLevel, Mode=TwoWay}"
                          HorizontalAlignment="Left" VerticalAlignment="Center" Width="140" Margin="0,6,24,6" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Padding="0,5,12,5">Border Width:</TextBlock>
                <NumberBox x:Name="BorderWidthTextBox" Value="{x:Bind settings.BorderWidth, Mode=TwoWay}"
                            SpinButtonPlacementMode="Inline" Minimum="0" Maximum="999" HorizontalAlignment="Left" VerticalAlignment="Center" Width="150" Margin="0,6" Padding="5,3"/>
            </StackPanel>
        </VariableSizedWrapGrid>
        
        <Button x:Name="CopyButton" Content="Copy QR Code" Grid.Row="3" Margin="0,6,0,0"
                Click="CopyButton_Click"
                VerticalAlignment="Center" HorizontalAlignment="Right" Padding="10,3" Grid.ColumnSpan="4" />
    </Grid>
    
</Page>
